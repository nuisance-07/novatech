# ===========================================
# NovaTech Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your actual values
# cp .env.example .env.local

# --- MongoDB (Required) ---
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/novatech?retryWrites=true&w=majority

# --- Clerk Authentication (Required) ---
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Stripe Payments (Required for checkout) ---
# Get from: https://dashboard.stripe.com → API Keys
STRIPE_SECRET_KEY=sk_test_...

# --- Google AI / Gemini (Required for Nova Assistant) ---
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# --- Public URL (Required for Stripe redirects in production) ---
# Set to your Vercel URL in production
NEXT_PUBLIC_URL=http://localhost:3000
